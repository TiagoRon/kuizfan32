# Configuración de ejemplo — Copia este archivo como .env y completa los valores
# =====================================================================

# --- Proveedor de IA (Gemini) ---
GEMINI_API_KEY=tu_clave_api_de_gemini_aqui

# --- Proveedor de IA alternativo (gratuito, opcional) ---
# Si usas un modelo gratuito alternativo, configúralo aquí
# GROQ_API_KEY=tu_clave_api_de_groq_aqui

# --- TTS Premium (opcional) ---
# ELEVENLABS_API_KEY=tu_clave_api_de_elevenlabs_aqui
# OPENAI_API_KEY=tu_clave_api_de_openai_aqui

# --- Base de Datos ---
DATABASE_URL=sqlite+aiosqlite:///./quiz_generator.db

# --- Generación ---
DEFAULT_LANGUAGE=es
DEFAULT_DIFFICULTY=medio
DEFAULT_QUIZ_TYPE=trivia

# --- GitHub Actions ---
# Estas variables se inyectan automáticamente en GitHub Actions
# GITHUB_TOKEN=auto
# GITHUB_REPOSITORY=auto
